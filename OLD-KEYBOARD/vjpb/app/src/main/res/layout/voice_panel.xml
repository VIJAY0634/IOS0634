<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/voicePanel"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:background="@drawable/bg_voice_bar">

    <ImageView
        android:id="@+id/btnCloseVoice"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_close_ios"/>

    <TextView
        android:id="@+id/txtVoiceStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Transcribing..."
        android:textColor="#FFFFFF"
        android:textSize="18sp"/>

    <ImageView
        android:id="@+id/btnSendVoice"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_arrow_up"/>
</LinearLayout>