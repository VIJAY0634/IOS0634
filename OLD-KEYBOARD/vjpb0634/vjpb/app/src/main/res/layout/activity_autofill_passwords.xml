<?xml version="1.0" encoding="utf-8"?>
<ScrollView
     xmlns:android="http://schemas.android.com/apk/res/android"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#000000">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:padding="16dp"
         android:orientation="vertical">

        <RelativeLayout
             android:layout_height="60dp"
             android:layout_width="match_parent">

            <ImageButton
                 android:layout_height="44dp"
                 android:layout_width="44dp"
                 android:src="@android:drawable/ic_media_previous"
                 android:background="@android:color/transparent"
                 android:layout_centerVertical="true"
                 android:tint="#FFFFFF"
                 android:id="@+id/btnBack" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_centerInParent="true"
                 android:textSize="22sp"
                 android:textColor="#FFFFFF"
                 android:text="AutoFill &amp;Passwords"
                 android:textStyle="bold" />

        </RelativeLayout>

        <LinearLayout
             android:layout_height="72dp"
             android:layout_width="match_parent"
             android:background="@drawable/settings_group_bg"
             android:gravity="center_vertical"
             android:layout_marginTop="20dp"
             android:paddingHorizontal="20dp">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:textSize="18sp"
                 android:textColor="#FFFFFF"
                 android:layout_weight="1"
                 android:text="AutoFill Passwords and Passkeys" />

            <Switch
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:id="@+id/switchAutofill" />

        </LinearLayout>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:textSize="15sp"
             android:textColor="#8E8E93"
             android:layout_marginTop="12dp"
             android:text="Automatically suggest passwords, passkeys and verification codes when signing in to apps and websites." />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:textSize="26sp"
             android:textColor="#FFFFFF"
             android:layout_marginTop="28dp"
             android:text="AutoFill from:"
             android:textStyle="bold" />

        <LinearLayout
             android:layout_height="72dp"
             android:layout_width="match_parent"
             android:background="@drawable/settings_group_bg"
             android:gravity="center_vertical"
             android:layout_marginTop="12dp"
             android:paddingHorizontal="20dp">

            <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Passwords"
        android:textColor="#FFFFFF"
        android:textSize="18sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Passkeys, passwords and codes"
        android:textColor="#8E8E93"
        android:textSize="14sp"/>

</LinearLayout>

            <Switch
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:id="@+id/switchPasswords" />

        </LinearLayout>


<View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:layout_marginStart="70dp"
    android:layout_marginEnd="20dp"
    android:background="#2F2F2F"/>

        <LinearLayout
             android:layout_height="72dp"
             android:layout_width="match_parent"
             android:background="@drawable/settings_group_bg"
             android:gravity="center_vertical"
             android:layout_marginTop="1dp"
             android:paddingHorizontal="20dp">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:textSize="18sp"
                 android:textColor="#FFFFFF"
                 android:layout_weight="1"
                 android:text="Google" />

            <Switch
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:id="@+id/switchGoogle" />

        </LinearLayout>

    </LinearLayout>


<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Verification Codes"
    android:textStyle="bold"
    android:textColor="#8E8E93"
    android:textSize="16sp"
    android:layout_marginTop="24dp"
    android:layout_marginBottom="8dp"/>

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:background="@drawable/settings_group_bg"
    android:gravity="center_vertical"
    android:paddingHorizontal="20dp">

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Delete After Use"
        android:textColor="#FFFFFF"
        android:textSize="18sp"/>

    <Switch
        android:id="@+id/switchDeleteAfterUse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>


<TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="20dp"
    android:text="Automatically delete verification codes in Messages and Mail after they are used."
    android:textColor="#8E8E93"
    android:textSize="14sp"/>


<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:layout_marginTop="8dp"
    android:background="@drawable/settings_group_bg"
    android:gravity="center_vertical"
    android:paddingHorizontal="20dp">

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Set Up Codes In"
        android:textColor="#FFFFFF"
        android:textSize="18sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Passwords"
        android:textColor="#8E8E93"
        android:textSize="16sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:text="⌄"
        android:textColor="#8E8E93"
        android:textSize="18sp"/>

</LinearLayout>


<TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="&quot;Passwords&quot; will be used to open links and QR codes for setting up verification codes."
    android:textColor="#8E8E93"
    android:textSize="14sp"/>


</ScrollView>